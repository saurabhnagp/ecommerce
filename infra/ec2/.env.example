# Copy to .env on the EC2 host only — do not commit real values.
# AWS CLI on the instance uses this region for `aws ecr get-login-password`.
AWS_REGION=ap-south-1

# Full ECR registry host (no https) — used by deploy scripts / manual docker login
ECR_REGISTRY=977574653708.dkr.ecr.ap-south-1.amazonaws.com

# Full image URIs (CI sets tags to commit SHA; local/manual can use :latest)
USER_SERVICE_IMAGE=977574653708.dkr.ecr.ap-south-1.amazonaws.com/amcart/user-service:latest
PRODUCT_SERVICE_IMAGE=977574653708.dkr.ecr.ap-south-1.amazonaws.com/amcart/product-service:latest
UI_IMAGE=977574653708.dkr.ecr.ap-south-1.amazonaws.com/amcart/ui:latest

# Postgres
POSTGRES_USER=amcart
POSTGRES_PASSWORD=amcart_password
POSTGRES_DB=amcart_users
PRODUCT_DB=amcart_products

# JWT signing key — must be at least 32 characters (matches UserService validation)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ISSUER=amcart
JWT_AUDIENCE=amcart-api
