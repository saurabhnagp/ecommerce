<mxfile host="app.diagrams.net">
  <diagram name="Purchase Flow" id="purchase-flow">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Title -->
        <mxCell id="title" value="AmCart Purchase Flow - User Journey" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="400" height="40" as="geometry" />
        </mxCell>
        
        <!-- User -->
        <mxCell id="user" value="User" style="swimlane;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;startSize=50;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="200" height="1000" as="geometry" />
        </mxCell>
        
        <!-- Frontend -->
        <mxCell id="frontend" value="Nuxt.js Frontend" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14;startSize=50;" vertex="1" parent="1">
          <mxGeometry x="300" y="100" width="300" height="1000" as="geometry" />
        </mxCell>
        
        <!-- Backend Services -->
        <mxCell id="backend" value="Backend Services (.NET)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;startSize=50;" vertex="1" parent="1">
          <mxGeometry x="660" y="100" width="300" height="1000" as="geometry" />
        </mxCell>
        
        <!-- Payment Gateway -->
        <mxCell id="payment-gw" value="Razorpay" style="swimlane;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=14;startSize=50;" vertex="1" parent="1">
          <mxGeometry x="1020" y="100" width="200" height="1000" as="geometry" />
        </mxCell>
        
        <!-- Step 1: Browse Products -->
        <mxCell id="step1-user" value="1. Browse Products" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="user">
          <mxGeometry x="20" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step1-frontend" value="Display Product Catalog&#xa;GET /api/v1/products" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="80" width="260" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="edge1" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step1-user" target="step1-frontend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="300" y="200" as="sourcePoint" />
            <mxPoint x="350" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 2: View Product -->
        <mxCell id="step2-user" value="2. View Product Details" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="user">
          <mxGeometry x="20" y="160" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step2-frontend" value="GET /api/v1/products/{id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="160" width="260" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="edge2" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step2-user" target="step2-frontend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="300" y="300" as="sourcePoint" />
            <mxPoint x="350" y="250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 3: Add to Cart -->
        <mxCell id="step3-user" value="3. Add to Cart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="user">
          <mxGeometry x="20" y="240" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step3-frontend" value="POST /api/v1/cart/items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="240" width="260" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step3-backend" value="Cart Service&#xa;Add Item to Redis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="backend">
          <mxGeometry x="20" y="240" width="260" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="edge3a" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step3-user" target="step3-frontend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="300" y="400" as="sourcePoint" />
            <mxPoint x="350" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <mxCell id="edge3b" value="HTTP POST" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step3-frontend" target="step3-backend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="600" y="400" as="sourcePoint" />
            <mxPoint x="650" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 4: View Cart -->
        <mxCell id="step4-user" value="4. View Cart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="user">
          <mxGeometry x="20" y="320" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step4-frontend" value="GET /api/v1/cart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="320" width="260" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="edge4" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step4-user" target="step4-frontend">
