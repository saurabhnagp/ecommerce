        </mxCell>
        
        <!-- Step 11: Order Confirmation -->
        <mxCell id="step11-backend" value="Order Service&#xa;Confirm Order&#xa;Reserve Inventory&#xa;Send Notification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="backend">
          <mxGeometry x="20" y="940" width="260" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="step11-frontend" value="Display Order Confirmation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="940" width="260" height="50" as="geometry" />
