            <mxPoint x="350" y="950" as="targetPoint" />
            <Array as="points">
              <mxPoint x="100" y="785" />
              <mxPoint x="1120" y="785" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Step 10: Payment Callback -->
