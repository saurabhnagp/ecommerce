          <mxGeometry x="20" y="840" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step10-backend" value="Payment Service&#xa;Verify Payment&#xa;Update Order Status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="backend">
          <mxGeometry x="20" y="840" width="260" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="edge10" value="Webhook" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step10-payment" target="step10-backend">
