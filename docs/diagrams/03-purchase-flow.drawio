        <mxCell id="edge5" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step5-user" target="step5-frontend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="300" y="600" as="sourcePoint" />
            <mxPoint x="350" y="550" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 6: Enter Billing/Shipping -->
        <mxCell id="step6-user" value="6. Enter Billing &amp; Shipping Address" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="user">
          <mxGeometry x="20" y="480" width="160" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="step6-frontend" value="Validate Form Data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="480" width="260" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="edge6" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step6-user" target="step6-frontend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="300" y="700" as="sourcePoint" />
            <mxPoint x="350" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 7: Create Order -->
        <mxCell id="step7-user" value="7. Place Order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="user">
          <mxGeometry x="20" y="580" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step7-frontend" value="POST /api/v1/orders" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="580" width="260" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step7-backend" value="Order Service&#xa;Create Order (Pending)&#xa;Validate Inventory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="backend">
          <mxGeometry x="20" y="580" width="260" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="edge7a" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step7-user" target="step7-frontend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="300" y="800" as="sourcePoint" />
            <mxPoint x="350" y="750" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <mxCell id="edge7b" value="HTTP POST" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step7-frontend" target="step7-backend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="600" y="800" as="sourcePoint" />
            <mxPoint x="650" y="750" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 8: Initiate Payment -->
        <mxCell id="step8-backend" value="Payment Service&#xa;Create Payment Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="backend">
          <mxGeometry x="20" y="680" width="260" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step8-frontend" value="Redirect to Payment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="680" width="260" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step8-payment" value="Razorpay Checkout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="payment-gw">
          <mxGeometry x="20" y="680" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="edge8a" value="Payment Link" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step8-backend" target="step8-frontend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="600" y="900" as="sourcePoint" />
            <mxPoint x="650" y="850" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <mxCell id="edge8b" value="Redirect" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step8-frontend" target="step8-payment">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1020" y="900" as="sourcePoint" />
            <mxPoint x="1070" y="850" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 9: Complete Payment -->
        <mxCell id="step9-user" value="9. Complete Payment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="user">
          <mxGeometry x="20" y="760" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="step9-payment" value="Process Payment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="payment-gw">
          <mxGeometry x="20" y="760" width="160" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="edge9" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step9-user" target="step9-payment">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
