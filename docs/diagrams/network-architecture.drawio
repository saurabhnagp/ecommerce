        <mxCell id="flow_box" value="&lt;div style=&quot;text-align:left;font-size:10px;line-height:1.8&quot;&gt;&#xa;&lt;b style=&quot;font-size:12px&quot;&gt;Request Flow (API traffic)&lt;/b&gt;&lt;br&gt;&#xa;&lt;b&gt;1.&lt;/b&gt; User → &lt;b style=&quot;color:#8C4FFF&quot;&gt;Route 53&lt;/b&gt; (DNS resolution, health-check failover to DR)&lt;br&gt;&#xa;&lt;b&gt;2.&lt;/b&gt; → &lt;b style=&quot;color:#DD344C&quot;&gt;AWS WAF&lt;/b&gt; (rate-limit, geo-block, SQL/XSS rules)&lt;br&gt;&#xa;&lt;b&gt;3.&lt;/b&gt; → &lt;b style=&quot;color:#8C4FFF&quot;&gt;ALB&lt;/b&gt; (HTTPS termination via ACM, cross-AZ)&lt;br&gt;&#xa;&lt;b&gt;4.&lt;/b&gt; → &lt;b style=&quot;color:#ED7100&quot;&gt;Nginx Ingress Pod&lt;/b&gt; (TLS internal, rate-limit, CORS, path routing)&lt;br&gt;&#xa;&lt;b&gt;5.&lt;/b&gt; → &lt;b style=&quot;color:#ED7100&quot;&gt;Ocelot API Gateway Pod&lt;/b&gt; (JWT validation, routing, aggregation, circuit breaker)&lt;br&gt;&#xa;&lt;b&gt;6.&lt;/b&gt; → &lt;b style=&quot;color:#ED7100&quot;&gt;Target Microservice Pod&lt;/b&gt; (business logic, DB access, event publish)&lt;br&gt;&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;overflow=hidden;fillColor=#FFFFFF;strokeColor=#232F3E;rounded=1;strokeWidth=2;" vertex="1" parent="1">
