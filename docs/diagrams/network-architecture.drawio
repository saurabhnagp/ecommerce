          <mxGeometry x="335" y="500" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="pri_sm" value="Secrets Mgr" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.secrets_manager;" vertex="1" parent="1">
          <mxGeometry x="455" y="500" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="pri_cw" value="CloudWatch + X-Ray" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;" vertex="1" parent="1">
          <mxGeometry x="155" y="600" width="40" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="hc_pri" value="Health Check (primary)" style="rounded=1;html=1;strokeColor=#248814;strokeWidth=2;fontSize=9;fontColor=#248814;labelBackgroundColor=#FFFFFF;" edge="1" source="r53" target="pri_alb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DR REGION -->
        <mxCell id="dr_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=3;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="750" y="180" width="550" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="dr_label" value="DR Region (ap-southeast-1)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="875" y="185" width="300" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="dr_status" value="PILOT LIGHT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F57F17;strokeColor=#E65100;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="215" width="110" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="dr_alb" value="ALB (standby)" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_load_balancing;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="1000" y="250" width="48" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="dr_eks" value="EKS (Scaled to Min / 0)&#xa;Same manifests · Scale-up on failover" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E8;strokeColor=#E65100;fontSize=10;fontStyle=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="320" width="430" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="dr_rds" value="RDS Cross-Region&#xa;Read Replica" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#C925D1;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.rds;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="795" y="400" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="dr_docdb" value="DocumentDB&#xa;Global (secondary)" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#C925D1;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.documentdb_with_mongodb_compatibility;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="925" y="400" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="dr_redis" value="ElastiCache&#xa;Global Datastore" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#C925D1;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elasticache;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="1055" y="400" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="dr_s3" value="S3 (CRR)" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#3F8624;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="795" y="510" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="dr_sm" value="Secrets Mgr&#xa;(replicated)" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.secrets_manager;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="925" y="510" width="40" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="hc_dr" value="Failover (if primary unhealthy)" style="rounded=1;html=1;strokeColor=#E65100;strokeWidth=2;dashed=1;fontSize=9;fontColor=#E65100;labelBackgroundColor=#FFFFFF;" edge="1" source="r53" target="dr_alb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Cross-region replication arrows -->
        <mxCell id="xr_rds" value="Cross-Region Replication" style="rounded=1;html=1;strokeColor=#C925D1;strokeWidth=2;dashed=1;fontSize=9;fontColor=#C925D1;labelBackgroundColor=#FFFFFF;" edge="1" source="pri_rds" target="dr_rds" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="xr_doc" value="Global Cluster" style="rounded=1;html=1;strokeColor=#C925D1;strokeWidth=2;dashed=1;fontSize=9;fontColor=#C925D1;labelBackgroundColor=#FFFFFF;" edge="1" source="pri_docdb" target="dr_docdb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="xr_redis" value="Global Datastore" style="rounded=1;html=1;strokeColor=#C925D1;strokeWidth=2;dashed=1;fontSize=9;fontColor=#C925D1;labelBackgroundColor=#FFFFFF;" edge="1" source="pri_redis" target="dr_redis" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="xr_s3" value="CRR" style="rounded=1;html=1;strokeColor=#3F8624;strokeWidth=2;dashed=1;fontSize=9;fontColor=#3F8624;labelBackgroundColor=#FFFFFF;" edge="1" source="pri_s3" target="dr_s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Failover steps -->
        <mxCell id="fo_box" value="&lt;div style=&quot;text-align:left;font-size:10px;line-height:1.8&quot;&gt;&#xa;&lt;b style=&quot;font-size:12px&quot;&gt;Pilot Light Failover Steps&lt;/b&gt;&lt;br&gt;&#xa;&lt;b&gt;1.&lt;/b&gt; Route 53 health check detects primary ALB failure&lt;br&gt;&#xa;&lt;b&gt;2.&lt;/b&gt; DNS automatically fails over to DR region ALB&lt;br&gt;&#xa;&lt;b&gt;3.&lt;/b&gt; RDS read replica promoted to standalone primary&lt;br&gt;&#xa;&lt;b&gt;4.&lt;/b&gt; DocumentDB global cluster promotes DR as primary&lt;br&gt;&#xa;&lt;b&gt;5.&lt;/b&gt; EKS node group scaled up (0 → target capacity)&lt;br&gt;&#xa;&lt;b&gt;6.&lt;/b&gt; ElastiCache global datastore promoted&lt;br&gt;&#xa;&lt;b&gt;7.&lt;/b&gt; SNS/SQS + SES provisioned in DR region (IaC)&lt;br&gt;&#xa;&lt;b&gt;RTO:&lt;/b&gt; ~15-30 min&amp;nbsp;&amp;nbsp;&lt;b&gt;RPO:&lt;/b&gt; seconds (async repl.) to minutes&lt;br&gt;&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;overflow=hidden;fillColor=#FFFFFF;strokeColor=#232F3E;rounded=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="760" width="450" height="130" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ===== TAB 3: CI/CD Pipeline (AWS Icons) ===== -->
  <diagram id="cicd" name="CI/CD Pipeline">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="AmCart — CI/CD Pipeline (GitHub Actions → ECR → EKS)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="dev" value="Developer" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.user;" vertex="1" parent="1">
          <mxGeometry x="35" y="130" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="github" value="GitHub&#xa;Source Repo · PR Checks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#24292E;strokeColor=#24292E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="125" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="gha_build" value="GitHub Actions&#xa;Restore · Build · Test&#xa;Lint · SAST" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2088FF;strokeColor=#1565C0;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="120" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="gha_docker" value="Docker Build&#xa;Multi-stage&#xa;Non-root · Read-only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2088FF;strokeColor=#1565C0;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="120" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ecr_push" value="Amazon ECR&#xa;Push Image" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ecr;" vertex="1" parent="1">
          <mxGeometry x="720" y="126" width="48" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="kubectl" value="kubectl / Helm&#xa;Rolling update&#xa;K8s manifests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2088FF;strokeColor=#1565C0;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="120" width="130" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="eks_target" value="Amazon EKS&#xa;Rolling Deploy&#xa;Zero-downtime" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_kubernetes_service;" vertex="1" parent="1">
          <mxGeometry x="891" y="250" width="48" height="48" as="geometry"/>
        </mxCell>

        <mxCell id="f1" style="rounded=1;html=1;strokeColor=#232F3E;strokeWidth=2;" edge="1" source="dev" target="github" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f2" value="trigger" style="rounded=1;html=1;strokeColor=#2088FF;strokeWidth=2;fontSize=9;fontColor=#2088FF;labelBackgroundColor=#FFFFFF;" edge="1" source="github" target="gha_build" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f3" style="rounded=1;html=1;strokeColor=#2088FF;strokeWidth=2;" edge="1" source="gha_build" target="gha_docker" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f4" value="push" style="rounded=1;html=1;strokeColor=#ED7100;strokeWidth=2;fontSize=9;fontColor=#ED7100;labelBackgroundColor=#FFFFFF;" edge="1" source="gha_docker" target="ecr_push" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f5" value="deploy" style="rounded=1;html=1;strokeColor=#2088FF;strokeWidth=2;fontSize=9;fontColor=#2088FF;labelBackgroundColor=#FFFFFF;" edge="1" source="ecr_push" target="kubectl" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f6" style="rounded=1;html=1;strokeColor=#ED7100;strokeWidth=2;" edge="1" source="kubectl" target="eks_target" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="env_note" value="&lt;div style=&quot;text-align:left;font-size:10px;line-height:1.8&quot;&gt;&#xa;&lt;b&gt;Environments&lt;/b&gt;&lt;br&gt;&#xa;&lt;b&gt;PR merge → main:&lt;/b&gt; Deploy to &lt;b&gt;staging&lt;/b&gt; EKS namespace&lt;br&gt;&#xa;&lt;b&gt;Tag / release:&lt;/b&gt; Deploy to &lt;b&gt;production&lt;/b&gt; EKS namespace&lt;br&gt;&#xa;&lt;b&gt;Image tags:&lt;/b&gt; git SHA (staging) · semver (production)&lt;br&gt;&#xa;&lt;b&gt;Secrets:&lt;/b&gt; Fetched at runtime from &lt;b&gt;AWS Secrets Manager&lt;/b&gt; via External Secrets Operator&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;overflow=hidden;fillColor=#FFFFFF;strokeColor=#232F3E;rounded=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="330" width="450" height="110" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
