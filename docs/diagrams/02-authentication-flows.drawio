        </mxCell>
        
        <mxCell id="step1-frontend" value="Redirect to Facebook" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="frontend">
          <mxGeometry x="20" y="60" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="edge1" value="Click" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step1-user" target="step1-frontend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="300" y="200" as="sourcePoint" />
            <mxPoint x="350" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 2: OAuth Dialog -->
        <mxCell id="step2-facebook" value="2. OAuth Dialog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="facebook">
          <mxGeometry x="20" y="140" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="edge2" value="Redirect" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step1-frontend" target="step2-facebook">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="820" y="200" as="sourcePoint" />
            <mxPoint x="870" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 3: Authorize -->
        <mxCell id="step3-user" value="3. Authorize AmCart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="user">
          <mxGeometry x="20" y="220" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="edge3" value="Authorize" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step3-user" target="step2-facebook">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="300" y="400" as="sourcePoint" />
            <mxPoint x="350" y="350" as="targetPoint" />
            <Array as="points">
              <mxPoint x="100" y="240" />
              <mxPoint x="1000" y="240" />
              <mxPoint x="1000" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Step 4: Callback -->
        <mxCell id="step4-facebook" value="4. Redirect with Code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="facebook">
          <mxGeometry x="20" y="300" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="step4-backend" value="GET /auth/facebook/callback?code=xxx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="backend">
          <mxGeometry x="20" y="300" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="edge4" value="Callback" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step4-facebook" target="step4-backend">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="780" y="400" as="sourcePoint" />
            <mxPoint x="830" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 5: Exchange Code -->
        <mxCell id="step5-backend" value="5. Exchange Code for Access Token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="backend">
          <mxGeometry x="20" y="380" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="step5-facebook" value="Return Access Token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="facebook">
          <mxGeometry x="20" y="380" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="edge5" value="GET /oauth/access_token" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step5-backend" target="step5-facebook">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="780" y="500" as="sourcePoint" />
            <mxPoint x="830" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 6: Get Profile -->
        <mxCell id="step6-backend" value="6. Get User Profile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="backend">
          <mxGeometry x="20" y="460" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="step6-facebook" value="Return Profile Data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="facebook">
          <mxGeometry x="20" y="460" width="160" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="edge6" value="GET /me" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="step6-backend" target="step6-facebook">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="780" y="600" as="sourcePoint" />
            <mxPoint x="830" y="550" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 7: Create/Link User -->
        <mxCell id="step7-backend" value="7. Create or Link User&#xa;Generate JWT Tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="backend">
          <mxGeometry x="20" y="540" width="160" height="60" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

