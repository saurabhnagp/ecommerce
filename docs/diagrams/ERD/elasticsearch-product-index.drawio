        <mxCell id="idx_products" value="products (index — mappings)" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#9673a6;fillColor=#e1d5e7;swimlaneLine=1;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="360" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="idx_products_a" value="&lt;b&gt;Field&lt;/b&gt; : &lt;b&gt;Type&lt;/b&gt; — &lt;b&gt;Purpose&lt;/b&gt;&lt;br&gt;─────────────────────&lt;br&gt;productId : keyword — exact match&lt;br&gt;productNumber : keyword&lt;br&gt;name : text + keyword — search &amp;amp; sort&lt;br&gt;description : text — full-text search&lt;br&gt;category : keyword — filter/agg&lt;br&gt;categoryName : text + keyword&lt;br&gt;subCategory : keyword — filter/agg&lt;br&gt;subCategoryName : text + keyword&lt;br&gt;brand : keyword — filter/agg&lt;br&gt;brandName : text + keyword&lt;br&gt;price : float — range filter &amp;amp; sort&lt;br&gt;discountPrice : float&lt;br&gt;colour : keyword — filter/agg&lt;br&gt;size : keyword — filter/agg&lt;br&gt;tags : keyword[] — multi-value filter&lt;br&gt;inStock : boolean — filter&lt;br&gt;stockQuantity : integer&lt;br&gt;rating : float — sort &amp;amp; boost&lt;br&gt;popularity : integer — sort &amp;amp; boost&lt;br&gt;isNew : boolean — boost&lt;br&gt;imageUrl : keyword — display only&lt;br&gt;createdAt : date — sort &amp;amp; filter&lt;br&gt;updatedAt : date — sync tracking" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="idx_products">
          <mxGeometry y="28" width="360" height="472" as="geometry"/>
        </mxCell>
        <mxCell id="idx_settings" value="Index Settings" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#9673a6;fillColor=#e1d5e7;swimlaneLine=1;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="320" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="idx_settings_a" value="number_of_shards : 1&lt;br&gt;number_of_replicas : 0&lt;br&gt;&lt;br&gt;&lt;b&gt;── custom analyzers ──&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;autocomplete_analyzer&lt;/b&gt;:&lt;br&gt;&amp;nbsp;&amp;nbsp;tokenizer: standard&lt;br&gt;&amp;nbsp;&amp;nbsp;filter: [lowercase, edge_ngram]&lt;br&gt;&lt;br&gt;&lt;b&gt;search_analyzer&lt;/b&gt;:&lt;br&gt;&amp;nbsp;&amp;nbsp;tokenizer: standard&lt;br&gt;&amp;nbsp;&amp;nbsp;filter: [lowercase]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="idx_settings">
