        <!-- ===== LEGEND ===== -->
        <mxCell id="legend" value="&lt;b&gt;Pattern&lt;/b&gt;: Publisher → SNS Topic → SQS Queue(s) → Consumer&lt;br&gt;&lt;br&gt;SNS &lt;b&gt;fans out&lt;/b&gt; each event to multiple SQS queues.&lt;br&gt;Each consumer reads from its &lt;b&gt;own dedicated queue&lt;/b&gt;.&lt;br&gt;Failed messages go to a &lt;b&gt;Dead Letter Queue&lt;/b&gt; (DLQ)." style="text;html=1;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;fontSize=11;" vertex="1" parent="1">
