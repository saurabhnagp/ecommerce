        <mxCell id="e_p2" value="PaymentCompleted&lt;br&gt;PaymentFailed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;fontSize=9;fontColor=#333333;" edge="1" source="pub_payment" target="topic_payment" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
