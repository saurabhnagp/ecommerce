        <mxCell id="r_cart" value="Shopping Cart (Hash)" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="350" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="r_cart_a" value="&lt;b&gt;Key&lt;/b&gt;: cart:{userId|sessionId}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: Hash&lt;br&gt;&lt;b&gt;TTL&lt;/b&gt;: 7 days (guest) / none (logged-in)&lt;br&gt;&lt;b&gt;── fields ──&lt;/b&gt;&lt;br&gt;items → JSON [{ productId, name,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;image, price, qty, subtotal }]&lt;br&gt;couponCode → string?&lt;br&gt;cartTotal → string (decimal)&lt;br&gt;updatedAt → ISO timestamp" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="r_cart">
          <mxGeometry y="28" width="350" height="172" as="geometry"/>
        </mxCell>
        <mxCell id="r_session" value="User Session (Hash)" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="460" y="40" width="320" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="r_session_a" value="&lt;b&gt;Key&lt;/b&gt;: session:{accessToken}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: Hash&lt;br&gt;&lt;b&gt;TTL&lt;/b&gt;: matches JWT expiry&lt;br&gt;&lt;b&gt;── fields ──&lt;/b&gt;&lt;br&gt;userId → string&lt;br&gt;email → string&lt;br&gt;role → string (Customer|Admin)&lt;br&gt;expiresAt → ISO timestamp" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="r_session">
          <mxGeometry y="28" width="320" height="162" as="geometry"/>
        </mxCell>
        <mxCell id="r_cache" value="Product Cache (String)" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="350" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="r_cache_a" value="&lt;b&gt;Key&lt;/b&gt;: cache:product:{productId}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: String (JSON blob)&lt;br&gt;&lt;b&gt;TTL&lt;/b&gt;: 15 minutes&lt;br&gt;&lt;b&gt;── value ──&lt;/b&gt;&lt;br&gt;Full product document from MongoDB&lt;br&gt;&lt;b&gt;Invalidation&lt;/b&gt;: DEL on product update&lt;br&gt;&lt;br&gt;Also: cache:productlist:{catId}:{page}" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="r_cache">
          <mxGeometry y="28" width="350" height="142" as="geometry"/>
        </mxCell>
        <mxCell id="r_stock" value="Stock Counter (String/Integer)" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="460" y="300" width="320" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="r_stock_a" value="&lt;b&gt;Key&lt;/b&gt;: stock:{productId}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: String (integer value)&lt;br&gt;&lt;b&gt;TTL&lt;/b&gt;: none (persistent)&lt;br&gt;&lt;b&gt;── operations ──&lt;/b&gt;&lt;br&gt;DECR → on purchase (atomic)&lt;br&gt;INCR → on restock (atomic)&lt;br&gt;Sync: periodic reconciliation with MongoDB" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="r_stock">
          <mxGeometry y="28" width="320" height="132" as="geometry"/>
        </mxCell>
        <mxCell id="r_popular" value="Popular Products (Sorted Set)" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="530" width="350" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="r_popular_a" value="&lt;b&gt;Key&lt;/b&gt;: popular:products&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: Sorted Set&lt;br&gt;&lt;b&gt;── structure ──&lt;/b&gt;&lt;br&gt;Members: productId strings&lt;br&gt;Score: view/purchase count&lt;br&gt;Use: ZREVRANGE for &amp;quot;Most Popular&amp;quot; section" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="r_popular">
          <mxGeometry y="28" width="350" height="112" as="geometry"/>
        </mxCell>
        <mxCell id="r_ratelimit" value="Rate Limiter (Sorted Set)" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="460" y="530" width="320" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="r_ratelimit_a" value="&lt;b&gt;Key&lt;/b&gt;: ratelimit:{ip}:{endpoint}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: Sorted Set&lt;br&gt;&lt;b&gt;── structure ──&lt;/b&gt;&lt;br&gt;Members: request timestamps&lt;br&gt;Window: sliding 60-second window&lt;br&gt;Max: 100 requests per window" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="r_ratelimit">
          <mxGeometry y="28" width="320" height="112" as="geometry"/>
        </mxCell>
        <mxCell id="note_flow" value="&lt;b&gt;Data Flow&lt;/b&gt;&lt;br&gt;• Cart → PostgreSQL Order on checkout&lt;br&gt;• Session populated on login from PostgreSQL&lt;br&gt;• Product cache filled from MongoDB on miss&lt;br&gt;• Stock counter synced with MongoDB hourly" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingLeft=4;strokeColor=#d6b656;fillColor=#fff2cc;fontSize=11;" vertex="1" parent="1">
