        <mxCell id="note_xdb" value="CategoryId and SubCategoryId are &lt;b&gt;cross-database&lt;br&gt;references&lt;/b&gt; to MongoDB categories collection.&lt;br&gt;No FK constraint — consistency maintained at&lt;br&gt;application level. ConditionJson uses PostgreSQL&lt;br&gt;jsonb for flexible combo-discount rules." style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingLeft=4;strokeColor=#d6b656;fillColor=#fff2cc;fontSize=11;" vertex="1" parent="1">
