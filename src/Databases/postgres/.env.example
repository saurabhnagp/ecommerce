# PostgreSQL - copy to .env and adjust as needed
# Used by docker-compose and optionally by deployment scripts.

POSTGRES_USER=amcart
POSTGRES_PASSWORD=amcart_password
POSTGRES_DB=amcart_users
# Data directory on host (optional; if unset, Docker uses a named volume)
# POSTGRES_DATA_DIR=./data

# Port exposed on host (default 5432)
POSTGRES_PORT=5432
