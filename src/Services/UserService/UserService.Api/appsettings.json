{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres.amcart-databases.svc.cluster.local;Port=5432;Database=amcart_users;Username=amcart;Password=amcart_password"
  },
  "Jwt": {
    "Secret": "amcart-user-service-secret-key-minimum-32-characters-long-for-hs256",
    "Issuer": "amcart",
    "Audience": "amcart-api",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "App": {
    "BaseUrl": "http://localhost:3000"
  },
  "ProductService": {
    "BaseUrl": "http://localhost:5002"
  }
}
