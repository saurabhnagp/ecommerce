# Leave empty for same-origin API (nginx gateway, CloudFront /api, or Vite dev proxy).
# VITE_USER_SERVICE_URL=

# Vite dev: omit (uses /product-api → ProductService). Docker/nginx static UI: set to /api.
# VITE_PRODUCT_SERVICE_URL=/api

# Optional: Vite dev proxy target if UserService is not on localhost:5001
# VITE_DEV_API_PROXY=http://localhost:5001

# Social login (SPA): public client IDs only. Secrets stay on UserService (OAuth:* in appsettings / env).
# Register the same redirect URIs in each provider console, e.g.:
#   http://localhost:5173/auth/callback/google
#   http://localhost:5173/auth/callback/facebook
#   http://localhost:5173/auth/callback/twitter
# UserService OAuth:Google|Facebook|Twitter:RedirectUriAllowlist must list those URLs exactly (prod + dev).
# VITE_GOOGLE_CLIENT_ID=
# VITE_FACEBOOK_APP_ID=
# VITE_TWITTER_CLIENT_ID=
