        <mxCell id="c_products_a" value="&lt;u&gt;_id&lt;/u&gt; : ObjectId&lt;br&gt;productNumber : string [unique]&lt;br&gt;name : string&lt;br&gt;description : string&lt;br&gt;price : Decimal128&lt;br&gt;discountPrice : Decimal128?&lt;br&gt;colour : string&lt;br&gt;size : string&lt;br&gt;stockQuantity : int&lt;br&gt;isInStock : boolean&lt;br&gt;rating : double&lt;br&gt;popularity : int&lt;br&gt;isNew : boolean&lt;br&gt;createdAt : Date&lt;br&gt;updatedAt : Date&lt;br&gt;&lt;b&gt;── embedded documents ──&lt;/b&gt;&lt;br&gt;category : { id, name }&lt;br&gt;subCategory : { id, name }&lt;br&gt;brand : { id, name }&lt;br&gt;images : [{ url, sortOrder }]&lt;br&gt;tags : [ string ]&lt;br&gt;&lt;b&gt;── indexes ──&lt;/b&gt;&lt;br&gt;{ productNumber: 1 } unique&lt;br&gt;{ &amp;quot;category.id&amp;quot;: 1, price: 1 }" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" vertex="1" parent="c_products">
