  <diagram id="redis-ds" name="Redis — Data Structures">
    <mxGraphModel dx="2084" dy="2143" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="db_label" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;strokeColor=#b85450;fillColor=#f8cecc;fontStyle=1;fontSize=14;" value="Redis" vertex="1">
          <mxGeometry height="50" width="100" x="340" y="-30" as="geometry" />
        </mxCell>
        <mxCell id="r_cart" parent="1" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" value="Shopping Cart (Hash)" vertex="1">
          <mxGeometry height="200" width="350" x="40" y="40" as="geometry" />
        </mxCell>
        <mxCell id="r_cart_a" parent="r_cart" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" value="&lt;b&gt;Key&lt;/b&gt;: cart:{userId|sessionId}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: Hash&lt;br&gt;&lt;b&gt;TTL&lt;/b&gt;: 7 days (guest) / none (logged-in)&lt;br&gt;&lt;b&gt;── fields ──&lt;/b&gt;&lt;br&gt;items → JSON [{ productId, name,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;image, price, qty, subtotal }]&lt;br&gt;couponCode → string?&lt;br&gt;cartTotal → string (decimal)&lt;br&gt;updatedAt → ISO timestamp" vertex="1">
          <mxGeometry height="172" width="350" y="28" as="geometry" />
        </mxCell>
        <mxCell id="r_session" parent="1" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" value="User Session (Hash)" vertex="1">
          <mxGeometry height="190" width="320" x="460" y="40" as="geometry" />
        </mxCell>
        <mxCell id="r_session_a" parent="r_session" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" value="&lt;b&gt;Key&lt;/b&gt;: session:{accessToken}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: Hash&lt;br&gt;&lt;b&gt;TTL&lt;/b&gt;: matches JWT expiry&lt;br&gt;&lt;b&gt;── fields ──&lt;/b&gt;&lt;br&gt;userId → string&lt;br&gt;email → string&lt;br&gt;role → string (Customer|Admin)&lt;br&gt;expiresAt → ISO timestamp" vertex="1">
          <mxGeometry height="162" width="320" y="28" as="geometry" />
        </mxCell>
        <mxCell id="r_cache" parent="1" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" value="Product Cache (String)" vertex="1">
          <mxGeometry height="170" width="350" x="40" y="300" as="geometry" />
        </mxCell>
        <mxCell id="r_cache_a" parent="r_cache" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" value="&lt;b&gt;Key&lt;/b&gt;: cache:product:{productId}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: String (JSON blob)&lt;br&gt;&lt;b&gt;TTL&lt;/b&gt;: 15 minutes&lt;br&gt;&lt;b&gt;── value ──&lt;/b&gt;&lt;br&gt;Full product document from MongoDB&lt;br&gt;&lt;b&gt;Invalidation&lt;/b&gt;: DEL on product update&lt;br&gt;&lt;br&gt;Also: cache:productlist:{catId}:{page}" vertex="1">
          <mxGeometry height="142" width="350" y="28" as="geometry" />
        </mxCell>
        <mxCell id="r_stock" parent="1" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" value="Stock Counter (String/Integer)" vertex="1">
          <mxGeometry height="160" width="320" x="460" y="300" as="geometry" />
        </mxCell>
        <mxCell id="r_stock_a" parent="r_stock" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" value="&lt;b&gt;Key&lt;/b&gt;: stock:{productId}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: String (integer value)&lt;br&gt;&lt;b&gt;TTL&lt;/b&gt;: none (persistent)&lt;br&gt;&lt;b&gt;── operations ──&lt;/b&gt;&lt;br&gt;DECR → on purchase (atomic)&lt;br&gt;INCR → on restock (atomic)&lt;br&gt;Sync: periodic reconciliation with MongoDB" vertex="1">
          <mxGeometry height="132" width="320" y="28" as="geometry" />
        </mxCell>
        <mxCell id="r_popular" parent="1" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" value="Popular Products (Sorted Set)" vertex="1">
          <mxGeometry height="140" width="350" x="40" y="530" as="geometry" />
        </mxCell>
        <mxCell id="r_popular_a" parent="r_popular" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" value="&lt;b&gt;Key&lt;/b&gt;: popular:products&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: Sorted Set&lt;br&gt;&lt;b&gt;── structure ──&lt;/b&gt;&lt;br&gt;Members: productId strings&lt;br&gt;Score: view/purchase count&lt;br&gt;Use: ZREVRANGE for &amp;quot;Most Popular&amp;quot; section" vertex="1">
          <mxGeometry height="112" width="350" y="28" as="geometry" />
        </mxCell>
        <mxCell id="r_ratelimit" parent="1" style="shape=swimlane;fontStyle=1;align=center;startSize=28;html=1;collapsible=0;rounded=1;shadow=0;strokeColor=#b85450;fillColor=#f8cecc;swimlaneLine=1;fontSize=13;arcSize=8;" value="Rate Limiter (Sorted Set)" vertex="1">
          <mxGeometry height="140" width="320" x="460" y="530" as="geometry" />
        </mxCell>
        <mxCell id="r_ratelimit_a" parent="r_ratelimit" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontStyle=0;html=1;fontSize=11;" value="&lt;b&gt;Key&lt;/b&gt;: ratelimit:{ip}:{endpoint}&lt;br&gt;&lt;b&gt;Type&lt;/b&gt;: Sorted Set&lt;br&gt;&lt;b&gt;── structure ──&lt;/b&gt;&lt;br&gt;Members: request timestamps&lt;br&gt;Window: sliding 60-second window&lt;br&gt;Max: 100 requests per window" vertex="1">
          <mxGeometry height="112" width="320" y="28" as="geometry" />
        </mxCell>
        <mxCell id="note_flow" parent="1" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingLeft=4;strokeColor=#d6b656;fillColor=#fff2cc;fontSize=11;" value="&lt;b&gt;Data Flow&lt;/b&gt;&lt;br&gt;• Cart → PostgreSQL Order on checkout&lt;br&gt;• Session populated on login from PostgreSQL&lt;br&gt;• Product cache filled from MongoDB on miss" vertex="1">
          <mxGeometry height="100" width="280" x="850" y="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
