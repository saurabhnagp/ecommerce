        <mxCell id="svc_items" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;" value="&lt;div style=&quot;text-align:left;font-size:11px;line-height:1.7&quot;&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;UserService&lt;/b&gt; — Auth, profile, social OAuth&lt;br&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;ProductService&lt;/b&gt; — Catalog, stock, CRUD&lt;br&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;CartService&lt;/b&gt; — Cart, coupons&lt;br&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;OrderService&lt;/b&gt; — Checkout, order lifecycle&lt;br&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;PaymentService&lt;/b&gt; — Stripe / PayPal&lt;br&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;SearchService&lt;/b&gt; — Full-text search, filters&lt;br&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;SaleService&lt;/b&gt; — Discounts, sale rules&lt;br&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;ReviewService&lt;/b&gt; — Reviews, testimonials, contact&lt;br&gt;&#xa;  &lt;b style=&quot;color:#1A73E8&quot;&gt;NotificationService&lt;/b&gt; — Email dispatch (SES)&#xa;&lt;/div&gt;" vertex="1">
